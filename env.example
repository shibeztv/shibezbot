# ─────────────────────────────────────────────────────────────
#  Twitch Markov Bot v2 — Environment Variables
#  Copy this to .env and fill in your values.
# ─────────────────────────────────────────────────────────────

# Bot's Twitch username
BOT_USERNAME=my_cool_bot

# OAuth token — get yours at https://twitchapps.com/tmi/
OAUTH_TOKEN=oauth:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Home channel (the bot always joins this one)
CHANNEL=your_channel_name

# Command prefix (default: $)
# CMD_PREFIX=$

# Note: only "shlbez" can use bot commands (hardcoded in commands.js)

# Path to seed text file (one message per line)
SEED_FILE=./seed.txt

# Comma-separated bot names to ignore (won't learn from them)
IGNORE_BOTS=nightbot,streamelements,fossabot,moobot,wizebot,botisimo

# Gemini API key — get yours free at https://aistudio.google.com/apikey
# Required for the ?gpt command. Leave blank to disable.
GEMINI_API_KEY=

# RapidAPI key — required for ?song command (Shazam, free 500/month)
# Sign up at https://rapidapi.com and subscribe to the Shazam API
RAPIDAPI_KEY=
